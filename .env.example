# Copiez ce fichier en .env  ->  cp env.example .env

# --- PostgreSQL ---
# En dev local (hors Docker), lancez juste la base : docker compose up -d db
DATABASE_URL="postgresql://jean:jean@localhost:5432/jean"

# --- Auth.js ---
# Générez un secret : npx auth secret   (ou : openssl rand -base64 33)
AUTH_SECRET=""

# --- Google OAuth ---
# Console : https://console.cloud.google.com/apis/credentials
# Type : "ID client OAuth" -> "Application Web"
# URI de redirection autorisée : http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# URL de base de l'app (utile derrière Docker / proxy)
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# --- Ollama (modèle IA local) ---
# Dev hors Docker : ollama pull qwen2:0.5b puis OLLAMA_URL ci-dessous.
# Avec docker compose up, l'app utilise automatiquement le service ollama.
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2:0.5b"
